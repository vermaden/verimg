# DEFAULTS
ARG_MODE=${ARG_MODE:-"fetch:build:setup"}
ARG_FILE=${ARG_FILE:-"VERIMG"}
ARG_SIZE=${ARG_SIZE:-"10g"}
ARG_VERS=${ARG_VERS:-"releng/15.0"}
ARG_INST=${ARG_INST:-"beadm:lsblk"}
ARG_MNTD=${ARG_MNTD:-"/mnt"}
ARG_KERN=${ARG_KERN:-"GENERIC"}
ARG_SRCD=${ARG_SRCD:-"/usr/src"}
ARG_TYPE=${ARG_TYPE:-"img"}
ARG_REPO=${ARG_REPO:-"/usr/obj/usr/src/repo/FreeBSD:15:$( uname -m )/latest"}
ARG_POOL=${ARG_POOL:-"sys"}
ARG_BRCH=${ARG_BRCH:-"latest"}

# pkg(8) KEYS
PKG_NME="pkg.freebsd.org.2013102301"
PKG_KEY="b0170035af3acc5f3f3ae1859dc717101b4e6c1d0a794ad554928ca0cbb2f438"
BCK_NME="backup-signing-15"
BCK_KEY="56a77bdcb6c3cf7984729c6138bd5617c24aa0d466b3b604c96205b2c5629f3c"
AWS_NME="awskms-15"
AWS_KEY="1d7b45d20fa8d6ed26f9b4a13ac81a6b5df860b9fe644d07b87e92298ba72595"

# TRAP FUNCTION TO CLEANUP (begin)
__verimg_clean() {

  # UNMOUNT devfs(5) FILESYSTEM FROM CHROOT
  umount -f "${ARG_MNTD}/dev" 2> /dev/null

  # EXPORT CREATE ZFS POOL
  if zpool list ${ARG_POOL} 1> /dev/null 2> /dev/null
  then
    zpool export -f ${ARG_POOL} 2> /dev/null
  fi

  # UNMAPE FILE FROM md(4) NODE
  if [ "${DEVICE}" != "" ]
  then
    mdconfig -d -u /dev/${DEVICE} 2> /dev/null
  fi

  # CHECK IF DISK IMAGE IS ALREADY MAPPED WITH md(4) DRIVER ON OTHER PLACES
  ARG_FILE_PATH="$( pwd )/${ARG_FILE}"
  mdconfig -l -v 2> /dev/null \
    | while read NAME TYPE SIZE FILENAME GARBAGE
      do

        if [ "${ARG_FILE_PATH}" = "${FILENAME}" ]
        then
          mdconfig -d -u /dev/${NAME} 2> /dev/null
        fi

      done
  }
# TRAP FUNCTION TO CLEANUP (end)

# CLEAN IN BETWEEN AND AFTER
trap __verimg_clean SIGINT SIGQUIT SIGHUP SIGTRAP SIGABRT SIGTERM

